{%- set pageAbsUrl = site.baseUrl + "/" + (permalink if permalink != "index.html" else "") -%}
<!doctype html>
<html lang="de">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<meta name="description" content="{{ description }}">
<title>{{ title }}</title>
<link rel="icon" href="assets/images/logo.svg" type="image/svg+xml">
<link rel="apple-touch-icon" href="assets/images/logo.png">
<meta name="theme-color" content="#203b27">
{%- if noindex %}
<meta name="robots" content="noindex">
{%- endif %}
<link rel="canonical" href="{{ pageAbsUrl }}">
<meta property="og:type" content="website">
<meta property="og:locale" content="de_DE">
<meta property="og:site_name" content="Jungenwaldmühle">
<meta property="og:title" content="{{ ogTitle or title }}">
<meta property="og:description" content="{{ description }}">
<meta property="og:url" content="{{ pageAbsUrl }}">
{%- if image %}
<meta property="og:image" content="{{ site.baseUrl }}/{{ image }}">
<meta property="og:image:width" content="{{ imageW }}">
<meta property="og:image:height" content="{{ imageH }}">
<meta name="twitter:card" content="summary_large_image">
{%- endif %}
{%- if preloadHero %}
<link rel="preload" as="image" href="assets/images/restaurant-hero.jpg" fetchpriority="high">
{%- endif %}
<link rel="stylesheet" href="assets/styles.css">
</head>
<body>
<a class="skip" href="#main">Zum Inhalt springen</a>
<header class="site-header"><div class="container nav"><a class="brand" href="index.html" aria-label="Jungenwaldmühle – Startseite"><img src="assets/images/logo.svg" alt="" width="48" height="48" loading="lazy"><span><strong>Jungenwaldmühle</strong><small>Restaurant · Hofcafé · Reitschule</small></span></a><button class="toggle" aria-label="Navigation öffnen" aria-expanded="false" aria-controls="nav">☰</button><nav class="links" id="nav" aria-label="Hauptnavigation">{% for item in site.nav %}<a href="{{ item.href }}"{% if item.key == navKey %} aria-current="page"{% endif %}>{{ item.label }}</a>{% endfor %}<a class="btn btn-primary" href="kontakt.html#reservierung">Tisch reservieren</a></nav></div></header>
{{ content | safe }}
<footer class="footer"><div class="container footer-grid"><div><h2>Jungenwaldmühle</h2><p>Ein besonderer Ort zwischen regionaler Küche, Natur und Islandpferden.</p></div><div><h3>Besuchen</h3><p>Jungenwaldmühle 1<br>54472 Brauneberg</p></div><div><h3>Kontakt</h3><p><a href="tel:+4965347493854">06534 7493854</a><br><a href="kontakt.html">Nachricht senden</a></p></div><div><h3>Entdecken</h3><p><a href="restaurant.html">Restaurant</a><br><a href="reitschule.html">Reitschule</a><br><a href="islandpferde.html">Islandpferde</a></p></div></div><div class="container legal">© <span data-year></span> Jungenwaldmühle · Konzeptseite zur Präsentation · <a href="impressum.html">Impressum & Datenschutz</a></div></footer>
<script src="assets/app.js"></script>
{%- if jsonLd %}
<script type="application/ld+json">{{ jsonLd | safe }}</script>
{%- endif %}
</body>
</html>
